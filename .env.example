# Robinhood Crypto Trading API credentials (never commit real values)
RH_API_KEY=rh-api-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RH_PRIVATE_KEY_BASE64=

# Bearer token Bankr / agents use to call THIS gateway (generate a long random string)
RH_WALLET_API_KEY=change-me-to-a-long-random-token

# Optional overrides
# RH_BASE_URL=https://trading.robinhood.com
MAX_ORDER_USD=50
REQUIRE_CONFIRMATION=true
PORT=8080
LOG_LEVEL=info
