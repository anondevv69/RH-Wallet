# Robinhood Crypto Trading API credentials (legacy single-tenant mode only)
# For universal hosting, users connect at /connect — leave these empty on Railway.
RH_API_KEY=
RH_PRIVATE_KEY_BASE64=

# Legacy single-tenant Bearer token (optional if using multi-tenant /connect)
RH_WALLET_API_KEY=

# Universal multi-tenant hosting (Railway)
# Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=
# Railway Postgres URL (recommended in production)
DATABASE_URL=
# Public HTTPS URL Bankr users set as RH_WALLET_API_URL
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Optional overrides
# RH_BASE_URL=https://trading.robinhood.com
MAX_ORDER_USD=50
REQUIRE_CONFIRMATION=true
PORT=8080
LOG_LEVEL=info
