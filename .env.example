# Robinhood Crypto Trading API credentials
# STATELESS MODE (default): users put RH keys in Bankr env — leave these empty on Railway.
RH_API_KEY=
RH_PRIVATE_KEY_BASE64=

# Legacy single-tenant only (optional)
RH_WALLET_API_KEY=

# Public stateless gateway (Railway host)
PUBLIC_BASE_URL=https://rhwallet-rhagent-production.up.railway.app
# Public hosted gateway secret (see skill/references/hosted-config.md)
GATEWAY_SHARED_SECRET=uniqueissomethingimtesting

# Safety
MAX_ORDER_USD=50
REQUIRE_CONFIRMATION=true
PORT=8080
LOG_LEVEL=info

# Experimental key storage via /connect — OFF by default
ENABLE_CONNECT_STORAGE=false
# MASTER_ENCRYPTION_KEY=
# DATABASE_URL=
